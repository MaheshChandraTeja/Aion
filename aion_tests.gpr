with "aion.gpr";

project Aion_Tests is
   for Source_Dirs use ("tests");
   for Object_Dir use "obj/tests";
   for Exec_Dir use "bin";
   for Main use ("test_runner.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2012", "-O0", "-g", "-gnata", "-gnatwa");
   end Compiler;
end Aion_Tests;
