# =============================================================================
# Aion .gitignore
# Structured asynchronous runtime for Ada
#
# Covers:
# - GNAT / GPRbuild build artifacts
# - Alire local state
# - Ada object/library files
# - Windows binaries and debug files
# - benchmark/test output
# - generated docs
# - release archives/installers
# - local IDE/editor files
# - temporary patches and extracted ZIPs
# - logs, caches, secrets, and environment files
# =============================================================================


# =============================================================================
# GNAT / Ada / GPRbuild artifacts
# =============================================================================

# Ada compilation artifacts
*.ali
*.o
*.obj
*.a
*.so
*.dll
*.dylib
*.lib
*.exp
*.lexch

# GPRbuild exchange/bind/link artifacts
*.bexch
*.lexch
*.adb.stdout
*.adb.stderr

# GNAT bind-generated files
b__*.adb
b__*.ads
b_*.adb
b_*.ads

# GNAT coverage / profiling / traces
*.gcda
*.gcno
*.gcov
*.prof
*.trace
*.srctrace

# GNATprove / SPARK artifacts
gnatprove/
*.spark
*.alfa
*.siv

# GPRbuild output directories
obj/
obj-*/
obj_*/
.objects/
.gprbuild/

# Library output
lib/
lib64/

# Executable output
bin/
out/
build/
build-*/
debug/
release-build/


# =============================================================================
# Alire artifacts
# =============================================================================

# Alire local build/cache/config state
.alire/
alire/
alire.lock

# Optional: keep this ignored while local-pinning dependencies during development.
# Commit it only when you intentionally want reproducible dependency locking.
# If publishing to Alire, review this before release.
# alire.lock


# =============================================================================
# Aion release outputs
# =============================================================================

release/
releases/
dist/
artifacts/
packages/
publish/
pkg/
installer/
installers/

# Archives
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# Checksums / manifests generated during release
checksums.sha256.txt
checksums.sha512.txt
release-manifest.json
release-notes.generated.md
SBOM.json
sbom.json

# Windows installers / packages
*.msi
*.exe
*.msix
*.appx
*.appxbundle
*.msixbundle

# Linux packages
*.deb
*.rpm
*.AppImage

# macOS packages
*.pkg
*.dmg


# =============================================================================
# Ada executable artifacts
# =============================================================================

# Windows executables
*.exe

# Debug symbols and maps
*.pdb
*.ilk
*.map
*.dbg
*.debug
*.dSYM/
*.sym

# Static/dynamic runtime leftovers
*.dll.a
*.dll.lib


# =============================================================================
# Tests, benchmark, and runtime output
# =============================================================================

test-results/
test_output/
test-output/
coverage/
coverage-html/
reports/
benchmark-results/
bench-results/
benchmarks/output/
benchmarks/results/

# Runtime logs
logs/
log/
*.log
*.log.*
*.out
*.err

# Temporary diagnostic dumps
diagnostics/
diagnostic-output/
runtime-dumps/
crash-dumps/
*.dump
*.dmp


# =============================================================================
# Generated documentation
# =============================================================================

docs/generated/
docs/api/
docs/html/
docs/site/
site/
public/
book/
mdbook/
.adoc-output/

# Documentation build caches
.mermaid-cache/
.plantuml-cache/


# =============================================================================
# Temporary patch files and extracted folders
# =============================================================================

patches/tmp/
tmp/
temp/
.tmp/
.cache/
.cache-*/
scratch/
sandbox/

# Aion module patch ZIPs and extracted patch folders
aion_module*_patch/
aion_module*_patch.zip
aion_*_patch/
aion_*_patch.zip

# Local extracted module folders
aion_module1/
aion_module2/
aion_module3/
aion_module4/
aion_module5/
aion_module6/
aion_module7/
aion_module8/
aion_module9/
aion_module10/

# Patch manifests are usually temporary unless deliberately included in release docs
PATCH_MANIFEST.md


