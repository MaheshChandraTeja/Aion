Zone.Identifier

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd

# Linux
.directory
.Trash-*
.nfs*


# =============================================================================
# PowerShell / script temporary files
# =============================================================================

*.ps1xml
*.pssc
*.psrc
PowerShell_transcript*.txt

# Script-generated local files
tools/tmp/
tools/output/
tools/logs/


# =============================================================================
# Python helper artifacts
# =============================================================================
# Ignore these because docs/tools/scripts may use Python helpers later.

__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
*.egg-info/


# =============================================================================
# Node / web tooling artifacts
# =============================================================================
# Ignore in case docs site or release tooling later uses JS tooling.
# Because one innocent documentation site somehow becomes 700 MB of node_modules.
# Humanity remains undefeated at making folders worse.

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

.next/
.nuxt/
vite.config.ts.timestamp-*
vite.config.js.timestamp-*


# =============================================================================
# C/C++ interop artifacts
# =============================================================================
# Useful if Aion later gets native reactor bindings.

CMakeFiles/
CMakeCache.txt
cmake-build-*/
compile_commands.json
Makefile
*.make
*.cmake

*.i
*.ii
*.s
*.asm


# =============================================================================
# Profiling / performance tooling
# =============================================================================

perf.data
perf.data.old
callgrind.out.*
cachegrind.out.*
massif.out.*
*.speedscope.json
flamegraph.svg


# =============================================================================
# Local databases / state files
# =============================================================================

*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal


# =============================================================================
# Network test leftovers
# =============================================================================

tcp-test-output/
udp-test-output/
socket-dumps/
pcaps/
*.pcap
*.pcapng


# =============================================================================
# Large generated files
# =============================================================================

*.iso
*.img
*.vhd
*.vhdx
*.qcow2


# =============================================================================
# Keep important source/config files tracked
# =============================================================================

!src/**/*.ads
!src/**/*.adb
!tests/**/*.adb
!tests/**/*.ads
!examples/**/*.adb
!examples/**/*.ads
!benchmarks/**/*.adb
!benchmarks/**/*.ads

!*.gpr
!alire.toml
!README.md
!LICENSE
!CHANGELOG.md

!docs/**/*.md
!tools/**/*.ps1
!tools/**/*.sh


# =============================================================================
# Project-specific notes
# =============================================================================

# Do not commit generated binaries, installers, local release ZIPs, test output,
# local Alire state, signing keys, or extracted patch folders.
#
# Commit:
# - source files
# - tests
# - examples
# - benchmark source
# - docs
# - project files
# - manifests intentionally required for reproducible builds
#
# Do not commit:
# - bin/
# - obj/
# - lib/
# - release/
# - dist/
# - *.exe
# - *.ali
# - *.o
# - *.a
# - signing keys
# =============================================================================