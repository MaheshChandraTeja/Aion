.env
.env.*
!.env.example

*.pem
*.key
*.crt
*.cer
*.pfx
*.p12
*.keystore
*.jks

secrets/
private/
credentials/
tokens/
keys/

# Signing material must never be committed.
*.sig
*.asc
codesign/
signing/
certs/


